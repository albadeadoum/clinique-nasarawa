{% block title %}Impression rendez-vous{% endblock %}

{% block body %}
<style>
  :root{
    --ink:#111827;
    --muted:#6b7280;
    --line:#e5e7eb;
    --card:#ffffff;
    --bg:#f9fafb;
  }

  body{ background: var(--bg); }

  @media print {
    @page { size: A4; margin: 12mm; }
    body { background: #fff !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .no-print { display: none !important; }
    .sheet { box-shadow: none !important; }
  }

  .wrap{
    max-width: 920px;
    margin: 24px auto;
    padding: 0 12px;
    font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    color: var(--ink);
  }

  .sheet{
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 10px 25px rgba(0,0,0,.06);
    overflow: hidden;
  }

  /* Header clinic */
  .clinic-head{
    padding: 18px 20px;
    border-bottom: 1px solid var(--line);
    display:flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
  }

  .clinic-left{
    display:flex;
    gap: 14px;
    align-items: center;
    min-width: 0;
  }

  .logo{
    width: 56px;
    height: 56px;
    border-radius: 999px;
    border: 2px solid var(--line);
    overflow: hidden;
    flex: 0 0 auto;
    background: #fff;
  }
  .logo img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display:block;
  }

  .clinic-meta{
    min-width: 0;
  }
  .clinic-name{
    margin: 0;
    font-weight: 900;
    font-size: 16px;
    letter-spacing: .2px;
  }
  .clinic-sub{
    margin-top: 4px;
    color: var(--muted);
    font-size: 12.5px;
    line-height: 1.35;
  }

  .actions{
    display:flex;
    gap: 10px;
    align-items: center;
    flex: 0 0 auto;
  }

  /* Title bar */
  .doc-head{
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
    display:flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    background: #fcfcfd;
  }
  .doc-title{
    margin: 0;
    font-size: 16px;
    font-weight: 900;
  }
  .doc-kpis{
    display:flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    color: var(--muted);
    font-size: 12.5px;
  }
  .doc-kpis b{ color: var(--ink); }

  .badge{
    display:inline-flex;
    align-items:center;
    gap: 6px;
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 900;
    border: 1px solid var(--line);
  }
  .dot{ width: 8px; height: 8px; border-radius: 999px; background: #9ca3af; }

  .is-ok{ background: #ecfdf5; border-color:#a7f3d0; color:#065f46; }
  .is-ok .dot{ background:#10b981; }

  .is-warn{ background:#fffbeb; border-color:#fde68a; color:#92400e; }
  .is-warn .dot{ background:#f59e0b; }

  .is-bad{ background:#fef2f2; border-color:#fecaca; color:#991b1b; }
  .is-bad .dot{ background:#ef4444; }

  /* Body */
  .content{ padding: 18px 20px 8px 20px; }

  .grid{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 16px;
  }

  .field{
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 12px;
    background: #fff;
  }
  .field.full{ grid-column: 1 / -1; }

  .label{
    font-size: 12px;
    color: var(--muted);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .04em;
    margin-bottom: 6px;
  }
  .value{
    font-size: 14px;
    font-weight: 650;
    line-height: 1.35;
    word-break: break-word;
  }

  .notes{
    min-height: 92px;
    border: 1px dashed var(--line);
    border-radius: 12px;
    padding: 12px;
    color: #374151;
    background: #fff;
  }

  .bottom{
    padding: 12px 20px 18px 20px;
    border-top: 1px dashed var(--line);
    display:flex;
    justify-content: space-between;
    align-items:flex-end;
    gap: 16px;
  }

  .sig{
    width: 58%;
    min-height: 82px;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 12px;
  }
  .sig .label{ margin-bottom: 8px; }

  .qr{
    width: 42%;
    display:flex;
    gap: 12px;
    align-items:center;
    justify-content:flex-end;
    text-align:right;
  }
  .qr img{
    width: 88px;
    height: 88px;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 6px;
    background: #fff;
  }
  .qr small{ color: var(--muted); display:block; line-height:1.35; }

  .btn{ border-radius: 10px; }
</style>

{# ==== Data safe ==== #}
{% set clinic_name = 'Clinique Nasarawa' %}
{% set clinic_addr = 'Niamey, Niger — Quartier …' %}
{% set clinic_phone = '+227 … … … …' %}
{% set clinic_email = 'contact@clinique.tld' %}

{% set patientNom = (rendez_vous.patient ? (rendez_vous.patient.nom ~ ' ' ~ (rendez_vous.patient.prenom ?? '')) : '—') %}
{% set medecinNom = (rendez_vous.medecin ? (rendez_vous.medecin.nomComplet ?? (rendez_vous.medecin.nom ~ ' ' ~ (rendez_vous.medecin.prenom ?? ''))) : '—') %}
{% set dt = (rendez_vous.dateheure ? rendez_vous.dateheure|date('d/m/Y H:i') : '—') %}
{% set statut = rendez_vous.statut ? rendez_vous.statut.value : '—' %}
{% set motif = (rendez_vous.motif ?: '—') %}
{% set dossier = (rendez_vous.patient and rendez_vous.patient.dossierMedical)
  ? (rendez_vous.patient.dossierMedical.numeroDossier ?? ('#' ~ rendez_vous.patient.dossierMedical.id))
  : '—'
%}

{# Badge mapping (adapte selon tes statuts exacts) #}
{% set badgeClass = 'badge' %}
{% if statut in ['PAYE','CONFIRME','TERMINE','VALIDE'] %}
  {% set badgeClass = badgeClass ~ ' is-ok' %}
{% elseif statut in ['EN_ATTENTE','PLANIFIE','EN_COURS'] %}
  {% set badgeClass = badgeClass ~ ' is-warn' %}
{% elseif statut in ['ANNULE','REFUSE','ABSENT'] %}
  {% set badgeClass = badgeClass ~ ' is-bad' %}
{% endif %}

{# QR: prefer provided data-uri (qr_data) else fallback to google chart URL #}
{% set showUrl = verifyUrl is defined ? verifyUrl : absolute_url(path('app_rendez_vous_show', {'id': rendez_vous.id})) %}
{% set _qr = qr_data is defined ? qr_data : ('https://chart.googleapis.com/chart?cht=qr&chs=200x200&chld=M|0&chl=' ~ showUrl|url_encode) %}

<div class="wrap">
  <div class="sheet">

    {# ===== Clinic header ===== #}
    <div class="clinic-head">
      <div class="clinic-left">
        <div class="logo">
          <img src="{{ asset('logo.png') }}" alt="Logo">
        </div>

        <div class="clinic-meta">
          <h2 class="clinic-name">{{ clinic_name }}</h2>
          <div class="clinic-sub">
            {{ clinic_addr }}<br>
            Tél : {{ clinic_phone }} — Email : {{ clinic_email }}
          </div>
        </div>
      </div>

      <div class="actions no-print">
        <a href="{{ path('app_rendez_vous_show', {'id': rendez_vous.id}) }}" class="btn btn-light border">
          Retour
        </a>
        <button type="button" onclick="window.print()" class="btn btn-primary">
          Imprimer
        </button>
      </div>
    </div>

    {# ===== Document title / meta ===== #}
    <div class="doc-head">
      <div>
        <h1 class="doc-title">Fiche de rendez-vous</h1>
        <div class="doc-kpis">
          <div><b>ID :</b> {{ rendez_vous.id }}</div>
          <div><b>Généré le :</b> {{ "now"|date('d/m/Y H:i') }}</div>
        </div>
      </div>

      <div>
        <span class="{{ badgeClass }}">
          <span class="dot"></span>
          {{ statut }}
        </span>
      </div>
    </div>

    {# ===== Content ===== #}
    <div class="content">
      <div class="grid">
        <div class="field">
          <div class="label">Patient</div>
          <div class="value">{{ patientNom|trim ?: '—' }}</div>
        </div>

        <div class="field">
          <div class="label">Dossier médical</div>
          <div class="value">{{ dossier }}</div>
        </div>

        <div class="field">
          <div class="label">Médecin</div>
          <div class="value">{{ medecinNom|trim ?: '—' }}</div>
        </div>

        <div class="field">
          <div class="label">Date & heure</div>
          <div class="value">{{ dt }}</div>
        </div>

        <div class="field full">
          <div class="label">Motif</div>
          <div class="value">{{ motif }}</div>
        </div>

        <div class="field full">
          <div class="label">Observations / Notes</div>
          <div class="notes">
            {# si tu as un champ notes, remplace par rendez_vous.notes #}
            —
          </div>
        </div>
      </div>
    </div>

    {# ===== Bottom: signature + QR ===== #}
    <div class="bottom">
      <div class="sig">
        <div class="label">Signature / Cachet</div>
        <div style="color: var(--muted); font-size: 12.5px;">
          Le : ____ / ____ / ______ &nbsp;&nbsp;&nbsp; Signature : ______________________
        </div>
      </div>

      <div class="qr">
        <div>
          <small><b>QR Code</b></small>
          <small>Vérifier le rendez-vous</small>
          <small style="word-break:break-all;">{{ showUrl }}</small>
          {% if code_qr is defined and code_qr %}
            <div><small><b>Code :</b> {{ code_qr }}</small></div>
          {% endif %}
        </div>
        <img src="{{ _qr }}" alt="QR Code">
      </div>
    </div>

  </div>
</div>
{% endblock %}