<div class="card mb-2 js-line-item">
  <div class="card-body">
    <div class="row g-2 align-items-end">
      <div class="col-md-4">
        {{ form_label(ligneForm.libelle, 'Médicament') }}
        {{ form_widget(ligneForm.libelle, { attr: { class: 'form-control form-control-sm' } }) }}
        {{ form_errors(ligneForm.libelle) }}
      </div>

      <div class="col-md-2">
        {{ form_label(ligneForm.quantite, 'Qté') }}
        {{ form_widget(ligneForm.quantite, { attr: { class: 'form-control form-control-sm' } }) }}
        {{ form_errors(ligneForm.quantite) }}
      </div>

      <div class="col-md-4">
        {{ form_label(ligneForm.posologie, 'Posologie') }}
        {{ form_widget(ligneForm.posologie, { attr: { class: 'form-control form-control-sm' } }) }}
        {{ form_errors(ligneForm.posologie) }}
      </div>

      <div class="col-md-1">
        {{ form_label(ligneForm.duree, 'Durée') }}
        {{ form_widget(ligneForm.duree, { attr: { class: 'form-control form-control-sm', placeholder: 'j' } }) }}
        {{ form_errors(ligneForm.duree) }}
      </div>

      <div class="col-md-1 text-end">
        <button type="button" class="btn btn-sm btn-outline-danger js-remove-line" title="Supprimer">
          <i class="ri-delete-bin-line"></i>
        </button>
      </div>
    </div>

    {# Champ _delete (si Symfony le génère automatiquement) #}
    {% if ligneForm._delete is defined %}
      <div class="d-none">
        {{ form_widget(ligneForm._delete) }}
      </div>
    {% endif %}
  </div>
</div>