{% extends 'base.html.twig' %}

{% block title %}Bon d'examen laboratoire{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set rdv = consultation.rendezVous|default(null) %}
    {% set patient = rdv ? rdv.patient|default(null) : null %}

    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h3 class="mb-1">Bon d'examen laboratoire</h3>
            <div class="text-muted small">
                Consultation #{{ consultation.id }}
            </div>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ path('app_laboratoire_index') }}" class="btn btn-outline-secondary">
                Retour
            </a>

            <a href="{{ path('app_laboratoire_bon_print', {id: consultation.id}) }}"
               target="_blank"
               class="btn btn-outline-dark">
                <i class="ri-printer-line me-1"></i> Imprimer
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Patient</div>
                <div class="card-body">
                    <div>
                        <strong>Nom :</strong>
                        {% if patient %}
                            {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                        {% else %}
                            -
                        {% endif %}
                    </div>
                    <div><strong>Consultation :</strong> #{{ consultation.id }}</div>
                    <div><strong>Rendez-vous :</strong> {{ rdv ? ('#' ~ rdv.id) : '-' }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Prescription</div>
                <div class="card-body">
                    <div>
                        <strong>Médecin :</strong>
                        {{ consultation.medecin.nomComplet|default((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim) }}
                    </div>
                    <div><strong>Date :</strong> {{ consultation.createdAt ? consultation.createdAt|date('Y-m-d H:i') : '-' }}</div>
                    <div><strong>Service :</strong> Laboratoire</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Statut global</div>
                <div class="card-body">
                    <div><strong>Nombre d'examens :</strong> {{ examens|length }}</div>
                    <div><strong>Facturation :</strong> Régularisée</div>
                    <div><strong>Destination :</strong> Laboratoire</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white fw-semibold">Examens demandés</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Examen</th>
                            <th>Quantité</th>
                            <th>Instructions</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for examen in examens %}
                        <tr>
                            <td>{{ examen.id }}</td>
                            <td>{{ examen.tarifPrestation.libelle }}</td>
                            <td>{{ examen.quantite }}</td>
                            <td>{{ examen.instructions ?: '-' }}</td>
                            <td>
                                {% if examen.statut.value == 'paye' %}
                                    <span class="badge bg-success">Payé</span>
                                {% elseif examen.statut.value == 'en_cours' %}
                                    <span class="badge bg-primary">En cours</span>
                                {% elseif examen.statut.value == 'realise' %}
                                    <span class="badge bg-secondary">Réalisé</span>
                                {% else %}
                                    <span class="badge bg-dark">{{ examen.statut.value }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}