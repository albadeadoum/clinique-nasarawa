<div class="modal-header border-0 pb-0 sticky-top bg-white" style="z-index: 2;">
    <h5 class="modal-title">
        {{ resultat.id ? 'Modifier le résultat laboratoire' : 'Saisir le résultat laboratoire' }}
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
</div>

{{ form_start(form, {'attr': {'id': 'resultatLaboratoireForm'}}) }}

<div class="modal-body pt-3"
     style="max-height: 70vh; overflow-y: auto;">
    <div class="alert alert-light border mb-3">
        <div><strong>Examen principal :</strong> {{ prestation.tarifPrestation.libelle }}</div>
        <div><strong>Quantité :</strong> {{ prestation.quantite }}</div>
        <div><strong>Statut actuel :</strong> {{ prestation.statut.value|replace({'_':' '})|title }}</div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="mb-0">Lignes de résultat</h6>
        <button type="button" class="btn btn-sm btn-outline-primary js-add-result-line">
            <i class="ri-add-line me-1"></i> Ajouter une ligne
        </button>
    </div>

    <div id="resultat-lignes"
         data-index="{{ form.lignes|length }}"
         data-prototype="{{ form_widget(form.lignes.vars.prototype)|e('html_attr') }}">
        {% for ligneForm in form.lignes %}
            <div class="card border mb-3 js-result-line-item shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="text-muted">Ligne de résultat</small>
                        <button type="button" class="btn btn-sm btn-outline-danger js-remove-result-line">
                            <i class="ri-delete-bin-line"></i>
                        </button>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-4">
                            {{ form_row(ligneForm.demande) }}
                        </div>
                        <div class="col-12 col-lg-4">
                            {{ form_row(ligneForm.resultat) }}
                        </div>
                        <div class="col-12 col-lg-3">
                            {{ form_row(ligneForm.valeurNormale) }}
                        </div>
                        <div class="col-12 col-lg-1">
                            {{ form_row(ligneForm.ordre) }}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="mt-3">
        {{ form_row(form.conclusion) }}
    </div>
</div>

<div class="modal-footer border-0 pt-0 sticky-bottom bg-white" style="z-index: 2;">
    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
    <button type="submit" class="btn btn-success js-submit-resultat">
        <i class="ri-save-line me-1"></i> Enregistrer
    </button>
</div>

{{ form_end(form) }}