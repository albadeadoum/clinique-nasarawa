<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Bon d'examen laboratoire</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 13px;
            color: #000;
            margin: 20px;
        }

        .title {
            text-align: center;
            margin-bottom: 20px;
        }

        .title h1 {
            margin: 0;
            font-size: 22px;
        }

        .title p {
            margin: 5px 0 0;
        }

        .row {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 20px;
        }

        .col {
            width: 48%;
        }

        .box {
            border: 1px solid #000;
            padding: 10px;
            border-radius: 4px;
        }

        .box h3 {
            margin-top: 0;
            margin-bottom: 10px;
            font-size: 14px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        table th,
        table td {
            border: 1px solid #000;
            padding: 8px;
            text-align: left;
        }

        table th {
            background: #f2f2f2;
        }

        .print-actions {
            margin-bottom: 20px;
        }

        @media print {
            .print-actions {
                display: none;
            }

            body {
                margin: 0;
            }

            @page {
                size: A4;
                margin: 12mm;
            }
        }
    </style>
</head>
<body>
    {% set rdv = consultation.rendezVous|default(null) %}
    {% set patient = rdv ? rdv.patient|default(null) : null %}

    <div class="print-actions">
        <button onclick="window.print()">Imprimer</button>
        <button onclick="window.close()">Fermer</button>
    </div>

    <div class="title">
        <h1>BON D'EXAMEN LABORATOIRE</h1>
        <p>Consultation #{{ consultation.id }}</p>
        <p>Date : {{ consultation.createdAt ? consultation.createdAt|date('d/m/Y H:i') : '-' }}</p>
    </div>

    <div class="row">
        <div class="col">
            <div class="box">
                <h3>Patient</h3>
                <p>
                    <strong>Nom :</strong>
                    {% if patient %}
                        {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                    {% else %}
                        -
                    {% endif %}
                </p>
                <p><strong>Rendez-vous :</strong> {{ rdv ? ('#' ~ rdv.id) : '-' }}</p>
                <p><strong>Consultation :</strong> #{{ consultation.id }}</p>
            </div>
        </div>

        <div class="col">
            <div class="box">
                <h3>Prescription</h3>
                <p>
                    <strong>Médecin :</strong>
                    {{ consultation.medecin.nomComplet|default((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim) }}
                </p>
                <p><strong>Destination :</strong> Laboratoire</p>
                <p><strong>Nombre d'examens :</strong> {{ examens|length }}</p>
            </div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Examen</th>
                <th>Qté</th>
                <th>Instructions</th>
            </tr>
        </thead>
        <tbody>
        {% for examen in examens %}
            <tr>
                <td>{{ loop.index }}</td>
                <td>{{ examen.tarifPrestation.libelle }}</td>
                <td>{{ examen.quantite }}</td>
                <td>{{ examen.instructions ?: '-' }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucun examen laboratoire.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div style="margin-top: 50px; display:flex; justify-content: space-between;">
        <div style="width: 40%; text-align:center;">
            <p><strong>Patient</strong></p>
            <br><br>
            <p>_____________________</p>
        </div>

        <div style="width: 40%; text-align:center;">
            <p><strong>Laboratoire</strong></p>
            <br><br>
            <p>_____________________</p>
        </div>
    </div>

    <script>
        window.addEventListener('load', function () {
            setTimeout(() => window.print(), 300);
        });
    </script>
</body>
</html>