{% extends 'base.html.twig' %}

{% block title %}Résultat laboratoire{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set consultation = prestation.consultation %}
    {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
    {% set patient = rdv ? rdv.patient|default(null) : null %}

    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h3 class="mb-1">Saisie du résultat laboratoire</h3>
            <div class="text-muted small">{{ prestation.tarifPrestation.libelle }}</div>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ path('app_laboratoire_show', {id: prestation.id}) }}" class="btn btn-outline-secondary">
                Retour
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Patient</div>
                <div class="card-body">
                    <div>
                        <strong>Nom :</strong>
                        {% if patient %}
                            {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                        {% else %}
                            -
                        {% endif %}
                    </div>
                    <div><strong>Consultation :</strong> #{{ consultation.id }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white fw-semibold">Formulaire de résultat</div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row g-3">
                            <div class="col-12">
                                {{ form_row(form.resultat) }}
                            </div>
                            <div class="col-12">
                                {{ form_row(form.conclusion) }}
                            </div>
                        </div>

                        <div class="mt-3 d-flex justify-content-end gap-2">
                            <a href="{{ path('app_laboratoire_show', {id: prestation.id}) }}" class="btn btn-light">
                                Annuler
                            </a>
                            <button type="submit" class="btn btn-success">
                                Enregistrer le résultat
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}