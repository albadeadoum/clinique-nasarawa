<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ticket caisse #{{ vente.id }}</title>
    <style>
        body { font-family: Arial, sans-serif; font-size: 13px; color: #000; margin: 20px; }
        .header { text-align: center; margin-bottom: 12px; }
        .header h2 { margin: 0; font-size: 18px; }
        .meta { display:flex; justify-content:space-between; gap:12px; margin-bottom:10px; }
        .box { border:1px solid #000; padding:8px; border-radius:4px; }
        table { width:100%; border-collapse: collapse; margin-top:10px; }
        th, td { border: 1px solid #000; padding:6px; text-align:left; }
        th { background:#f3f3f3; }
        .totals { width:320px; margin-left:auto; margin-top:10px; }
        .qr { text-align:right; }
        .print-actions { margin-top:16px; text-align:center; }
        @media print{ .print-actions{ display:none } @page { size:A4; margin:12mm } body{ margin:0 } }
    </style>
</head>
<body>

<div class="header">
    <h2>CLINIQUE NASARAWA - CAISSE PHARMACIE</h2>
    <div>Tel: +227 XX XX XX XX</div>
</div>

<div class="meta">
    <div class="box">
        <strong>Ticket :</strong> #{{ vente.id }}<br>
        <strong>Date :</strong> {{ vente.date ? vente.date|date('d/m/Y H:i') : '–' }}<br>
        <strong>Vendeur :</strong> {{ vente.vendeur ? vente.vendeur.nomComplet|default(vente.vendeur.getUserIdentifier ? vente.vendeur.getUserIdentifier() : '-') : '-' }}
    </div>

    <div class="box qr">
        {% set _qr = qr_data is defined ? qr_data : (verifyUrl is defined ? verifyUrl : null) %}
        {% if _qr %}
            <img src="{{ _qr }}" alt="QR" style="width:110px; height:110px;">
        {% endif %}
        {% if code_qr is defined and code_qr %}
            <div style="font-size:12px; margin-top:6px;">Code: {{ code_qr }}</div>
        {% endif %}
        {% if verifyUrl is defined and verifyUrl %}
            <div style="font-size:10px; margin-top:4px;">Vérifier: <a href="{{ verifyUrl }}">{{ verifyUrl }}</a></div>
        {% endif %}
    </div>
</div>

<table>
    <thead>
        <tr>
            <th>#</th>
            <th>Produit</th>
            <th>Qté</th>
            <th>PU</th>
            <th>Total</th>
        </tr>
    </thead>
    <tbody>
    {% for ligne in vente.lignes %}
        <tr>
            <td>{{ loop.index }}</td>
            <td>{{ ligne.medicament.nom }}</td>
            <td>{{ ligne.quantite }}</td>
            <td>{{ ligne.prixUnitaire|number_format(0, ',', ' ') }} FCFA</td>
            <td>{{ ligne.sousTotal|number_format(0, ',', ' ') }} FCFA</td>
        </tr>
    {% else %}
        <tr><td colspan="5">Aucune ligne</td></tr>
    {% endfor %}
    </tbody>
</table>

<div class="totals box">
    <table style="width:100%; border-collapse:collapse;">
        <tr>
            <th>Total</th>
            <td style="text-align:right">{{ vente.total|number_format(0, ',', ' ') }} FCFA</td>
        </tr>
    </table>
</div>

<div class="print-actions">
    <button onclick="window.print()">Imprimer</button>
</div>

</body>
</html>
