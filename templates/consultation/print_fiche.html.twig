<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Fiche de consultation #{{ consultation.id }}</title>
    <style>
        :root{
            --primary:#0f4c81;
            --dark:#1f2937;
            --muted:#6b7280;
            --line:#d1d5db;
            --soft:#f8fafc;
            --white:#ffffff;
        }

        *{
            box-sizing:border-box;
        }

        html, body{
            margin:0;
            padding:0;
            font-family: "Segoe UI", Arial, Helvetica, sans-serif;
            font-size:11px;
            color:var(--dark);
            background:#eef2f7;
        }

        .sheet{
            width:148mm;
            min-height:210mm;
            margin:10px auto;
            background:var(--white);
            border:1px solid #e5e7eb;
            box-shadow:0 6px 18px rgba(0,0,0,.08);
            overflow:hidden;
        }

        .top-bar{
            height:6px;
            background:linear-gradient(90deg, var(--primary), #1d7bb8);
        }

        .page{
            padding:9mm 8mm 8mm 8mm;
        }

        .topbar{
            display:flex;
            justify-content:space-between;
            align-items:flex-start;
            gap:10px;
            margin-bottom:8px;
            padding-bottom:8px;
            border-bottom:1px solid var(--line);
        }

        .clinic{
            flex:1;
        }

        .clinic h1{
            margin:0 0 4px 0;
            font-size:16px;
            color:var(--primary);
            font-weight:800;
            text-transform:uppercase;
            line-height:1.15;
        }

        .clinic .sub{
            color:var(--muted);
            line-height:1.35;
            font-size:10px;
        }

        .qr-box{
            width:34mm;
            text-align:center;
            border:1px solid var(--line);
            border-radius:8px;
            padding:4px;
            background:var(--soft);
        }

        .qr-box img{
            width:26mm;
            height:26mm;
            object-fit:contain;
            border:1px solid #e5e7eb;
            background:#fff;
            padding:2px;
            border-radius:6px;
        }

        .qr-box .qr-label{
            font-size:9px;
            margin-top:4px;
            color:var(--muted);
            line-height:1.2;
        }

        .title{
            text-align:center;
            font-size:15px;
            font-weight:800;
            margin:8px 0 10px 0;
            text-transform:uppercase;
            color:var(--dark);
            letter-spacing:.4px;
        }

        .meta{
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:6px 14px;
            margin-bottom:8px;
            border:1px solid var(--line);
            border-radius:8px;
            padding:8px;
            background:#fff;
        }

        .meta div{
            line-height:1.3;
        }

        .section{
            margin-top:8px;
        }

        .section-title{
            font-weight:800;
            background:var(--soft);
            border:1px solid var(--line);
            color:var(--primary);
            padding:6px 8px;
            margin-bottom:5px;
            border-radius:6px 6px 0 0;
            text-transform:uppercase;
            font-size:10.5px;
        }

        .box{
            border:1px solid var(--line);
            border-top:none;
            padding:8px;
            line-height:1.35;
            border-radius:0 0 6px 6px;
            background:#fff;
        }

        .box strong{
            color:#111827;
        }

        table{
            width:100%;
            border-collapse:collapse;
        }

        .table-wrap{
            border:1px solid var(--line);
            border-radius:0 0 6px 6px;
            overflow:hidden;
            background:#fff;
        }

        table th, table td{
            border:1px solid #e5e7eb;
            padding:6px 5px;
            vertical-align:top;
            font-size:10px;
        }

        table th{
            background:var(--primary);
            color:#fff;
            text-align:left;
            font-weight:700;
        }

        table tbody tr:nth-child(even){
            background:#fafafa;
        }

        .signature{
            margin-top:16px;
            display:flex;
            justify-content:space-between;
            gap:14px;
        }

        .signature-block{
            width:48%;
            text-align:center;
        }

        .line{
            margin-top:26px;
            border-top:1px solid #000;
            padding-top:4px;
            font-size:10px;
            color:var(--muted);
        }

        .footer-note{
            margin-top:12px;
            text-align:center;
            font-weight:800;
            font-size:11px;
            color:var(--primary);
            border-top:1px dashed var(--line);
            padding-top:8px;
        }

        .print-actions{
            margin-top:14px;
            text-align:center;
            border-top:1px solid #e5e7eb;
            padding-top:10px;
        }

        .btn-print{
            border:none;
            background:var(--primary);
            color:#fff;
            padding:8px 16px;
            border-radius:7px;
            font-size:11px;
            font-weight:700;
            cursor:pointer;
        }

        a{
            color:var(--primary);
            text-decoration:none;
            word-break:break-all;
        }

        @page{
            size:A5 portrait;
            margin:8mm;
        }

        @media print{
            html, body{
                background:#fff;
            }

            .sheet{
                width:100%;
                min-height:auto;
                margin:0;
                border:none;
                box-shadow:none;
            }

            .page{
                padding:0;
            }

            .print-actions{
                display:none !important;
            }
        }
    </style>
</head>
<body>

{% set patient = consultation.rendezVous.patient ?? null %}

<div class="sheet">
    <div class="top-bar"></div>

    <div class="page">
        <div class="topbar">
            <div class="clinic">
                <h1>Clinique Nassarawa</h1>
                <div class="sub">
                    Niamey - Niger<br>
                    Tél : +227 XX XX XX XX
                </div>
            </div>

            <div class="qr-box">
                {% set _qr = qr_data is defined ? qr_data : (qrCodeDataUri is defined ? qrCodeDataUri : null) %}
                {% if _qr %}
                    <img src="{{ _qr }}" alt="QR Code fiche consultation">
                {% endif %}
                <div class="qr-label">QR Consultation</div>
                {% if code_qr is defined and code_qr %}
                    <div class="qr-label">Code : {{ code_qr }}</div>
                {% endif %}
                {% if verifyUrl is defined and verifyUrl %}
                    <div class="qr-label"><a href="{{ verifyUrl }}">{{ verifyUrl }}</a></div>
                {% endif %}
            </div>
        </div>

        <div class="title">Fiche de consultation</div>

        <div class="meta">
            <div><strong>N° fiche :</strong> {{ consultation.id }}</div>
            <div><strong>N° consultation :</strong> {{ consultation.id }}</div>
            <div><strong>Date :</strong> {{ consultation.createdAt ? consultation.createdAt|date('d/m/Y H:i') : '-' }}</div>
            <div><strong>Service médical :</strong> {{ consultation.serviceMedical.nom ?? '-' }}</div>
        </div>

        <div class="section">
            <div class="section-title">Patient</div>
            <div class="box">
                <strong>Nom et prénom :</strong>
                {{ patient ? ((patient.nom ?? '') ~ ' ' ~ (patient.prenom ?? ''))|trim : '-' }}<br>

                <strong>Code patient :</strong>
                {{ patient and patient.code is defined ? patient.code : '-' }}<br>

                <strong>N° dossier médical :</strong>
                {{ consultation.dossierMedical and consultation.dossierMedical.numeroDossier is defined
                    ? consultation.dossierMedical.numeroDossier
                    : '-' }}<br>

                <strong>Téléphone :</strong>
                {{ patient and patient.telephone is defined ? patient.telephone : '-' }}
            </div>
        </div>

        <div class="section">
            <div class="section-title">Médecin</div>
            <div class="box">
                {{ consultation.medecin
                    ? ((consultation.medecin.nom ?? '') ~ ' ' ~ (consultation.medecin.prenom ?? ''))|trim
                    : '-' }}
            </div>
        </div>

        <div class="section">
            <div class="section-title">Prestations prescrites</div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 6%;">#</th>
                            <th style="width: 42%;">Prestation</th>
                            <th style="width: 20%;">Catégorie</th>
                            <th style="width: 12%;">Qté</th>
                            <th style="width: 20%;">Instructions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for p in consultation.prescriptionsPrestations %}
                        <tr>
                            <td>{{ loop.index }}</td>
                            <td>{{ p.tarifPrestation.libelle|default('-') }}</td>
                            <td>{{ p.tarifPrestation.categorie.value|default('-')|replace({'_':' '})|title }}</td>
                            <td>{{ p.quantite|default(1) }}</td>
                            <td>{{ p.instructions ?: '-' }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">Aucune prestation prescrite</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Observations médicales</div>
            <div class="box">
                <strong>Motif :</strong> {{ consultation.motifs ?: '-' }}<br><br>
                <strong>Diagnostic :</strong> {{ consultation.diagnostic ?: '-' }}<br><br>
                <strong>Conduite à tenir :</strong> {{ consultation.conduiteATenir ?: '-' }}
            </div>
        </div>

        <div class="signature">
            <div class="signature-block">
                <div class="line">Signature du médecin</div>
            </div>

            <div class="signature-block">
                <div class="line">Cachet du service</div>
            </div>
        </div>

        <div class="footer-note">
            À PRÉSENTER À LA CAISSE POUR RÈGLEMENT
        </div>

       
    </div>
</div>

</body>
</html>