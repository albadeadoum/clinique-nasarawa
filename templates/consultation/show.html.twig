{% extends 'base.html.twig' %}

{% block title %}Consultation #{{ consultation.id }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ===================== HEADER ===================== #}
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h3 class="mb-1">
                Consultation <span class="text-muted">#{{ consultation.id }}</span>
            </h3>

            <div class="text-muted small">
                {% if consultation.rendezVous is defined and consultation.rendezVous %}
                    RDV #{{ consultation.rendezVous.id }}
                    {% if consultation.rendezVous.dateHeure is defined %}
                        — {{ consultation.rendezVous.dateHeure|date('Y-m-d H:i') }}
                    {% endif %}
                {% endif %}
            </div>

            <div class="mt-2 d-flex flex-wrap gap-2">
                {# Statut consultation #}
                {% if consultation.statut is defined and consultation.statut %}
                    {% set st = consultation.statut.name ?? consultation.statut.value ?? '' %}
                    {% set badgeClass =
                        st in ['EN_COURS'] ? 'bg-primary' :
                        st in ['BROUILLON'] ? 'bg-secondary' :
                        st in ['CLOTURE','CLOTUREE'] ? 'bg-success' :
                        st in ['ANNULE','ANNULEE'] ? 'bg-danger' :
                        'bg-dark'
                    %}
                    <span class="badge {{ badgeClass }}">{{ st }}</span>
                {% endif %}

                {# Médecin #}
{#                 {% if consultation.medecin is defined and consultation.medecin %}
                    <span class="badge bg-light text-dark border">
                        Médecin :
                        {% if consultation.medecin %}
                        <span class="badge bg-light text-dark border">
                            Médecin :
                            {{ consultation.medecin.nomComplet
                                ?? (consultation.medecin.nom ~ ' ' ~ consultation.medecin.prenom)
                                ?? consultation.medecin.id
                            }}
                        </span>
                    {% endif %}
                    </span>
                {% endif %} #}

               {# Patient #}
                {% set rdv = consultation.rendezVous|default(null) %}
                {% set patient = rdv ? (rdv.patient|default(null)) : null %}

                {% if patient %}
                    <span class="badge bg-light text-dark border">
                        Patient :
                        {{ patient.nomComplet
                            |default(((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim))
                            |default(patient.id)
                        }}
                    </span>
                {% endif %}
            </div>
        </div>

        {# ===================== ACTIONS ===================== #}
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_consultation_index') }}" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Retour
            </a>

            {# Bouton édition Phase C : désactivé si clôturée/annulée #}
            {% set stName = (consultation.statut.name ?? '') %}
            {% set locked = stName in ['CLOTURE', 'CLOTUREE', 'ANNULE', 'ANNULEE'] %}

           <button type="button"
                class="btn btn-primary js-edit-consultation {{ locked ? 'disabled' : '' }}"
                title="Saisie médicale"
                data-bs-toggle="modal"
                data-bs-target="#editConsultationModal"
                data-url="{{ path('app_consultation_medical_edit', {'id': consultation.id}) }}"
                {{ locked ? 'disabled' : '' }}>
                
            <i class="fa fa-pen me-1"></i> Saisie médicale
        </button>

         <button type="button"
                class="btn btn-outline-success js-open-facture"
                data-bs-toggle="modal"
                data-bs-target="#factureModal"
                data-url="{{ path('app_consultation_facture_modal', {id: consultation.id}) }}">
        <i class="ri-bill-line me-1"></i> Facturer
        </button>

        <button type="button"
        class="btn btn-outline-primary js-open-prescription"
        data-bs-toggle="modal"
        data-bs-target="#prescriptionModal"
        data-url="{{ path('app_consultation_prescription_modal', {id: consultation.id}) }}">
  <i class="ri-file-text-line me-1"></i> Prescription
</button>

            {# On garde delete mais idéalement réservé admin #}
            {{ include('consultation/_delete_form.html.twig') }}
        </div>
    </div>

    {# ===================== KPI CARDS (Constantes) ===================== #}
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Poids</div>
                    <div class="fs-4 fw-semibold">
                        {{ consultation.poids ?? '-' }} <span class="text-muted fs-6">kg</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Taille</div>
                    <div class="fs-4 fw-semibold">
                        {{ consultation.taille ?? '-' }} <span class="text-muted fs-6">cm</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Température</div>
                    <div class="fs-4 fw-semibold">
                        {{ consultation.temperature ?? '-' }} <span class="text-muted fs-6">°C</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Fréquence cardiaque</div>
                    <div class="fs-4 fw-semibold">
                        {{ consultation.frequenceCardiaque ?? '-' }} <span class="text-muted fs-6">bpm</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ===================== TABS ===================== #}
    <ul class="nav nav-tabs" id="consultTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-clinique" data-bs-toggle="tab" data-bs-target="#pane-clinique"
                    type="button" role="tab">
                Clinique
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-prescriptions" data-bs-toggle="tab" data-bs-target="#pane-prescriptions"
                    type="button" role="tab">
                Prescriptions
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-examens" data-bs-toggle="tab" data-bs-target="#pane-examens"
                    type="button" role="tab">
                Examens demandés
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-actes" data-bs-toggle="tab" data-bs-target="#pane-actes"
                    type="button" role="tab">
                Actes réalisés
            </button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-3" id="consultTabsContent">

        {# ========== CLINIQUE ========== #}
        <div class="tab-pane fade show active" id="pane-clinique" role="tabpanel">
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">Motif & Histoire</div>
                        <div class="card-body">
                            <div class="mb-2">
                                <div class="text-muted small">Motifs</div>
                                <div>{{ consultation.motifs ?? '-' }}</div>
                            </div>
                            <div>
                                <div class="text-muted small">Histoire / Anamnèse</div>
                                <div>{{ consultation.histoire ?? '-' }}</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">Examen & Diagnostic</div>
                        <div class="card-body">
                            <div class="mb-2">
                                <div class="text-muted small">Examen clinique</div>
                                <div>{{ consultation.examenClinique ?? '-' }}</div>
                            </div>

                            <div class="mb-2">
                                <div class="text-muted small">Tension artérielle</div>
                                <div>{{ consultation.tensionArterielle ?? '-' }}</div>
                            </div>

                            <div class="mb-2">
                                <div class="text-muted small">Diagnostic (texte)</div>
                                <div>{{ consultation.diagnostic ?? '-' }}</div>
                            </div>

                            <div>
                                <div class="text-muted small">Diagnostic CIM10 (optionnel)</div>
                                <div>
                                    {% if consultation.cim10 is defined and consultation.cim10 %}
                                        {{ consultation.cim10 }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card">
                        <div class="card-header fw-semibold">Conduite à tenir</div>
                        <div class="card-body">
                            {{ consultation.conduiteATenir ?? '-' }}
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">
                        Créée : {{ consultation.createdAt ? consultation.createdAt|date('Y-m-d H:i') : '-' }}
                        — Modifiée : {{ consultation.modifiedAt ? consultation.modifiedAt|date('Y-m-d H:i') : '-' }}
                    </div>
                </div>
            </div>
        </div>

        {# ========== PRESCRIPTIONS ========== #}
        <div class="tab-pane fade" id="pane-prescriptions" role="tabpanel">
            {% if consultation.prescriptions is defined and consultation.prescriptions|length > 0 %}
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Commentaire</th>
                            <th class="text-end">Lignes</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for p in consultation.prescriptions %}
                            <tr>
                                <td>{{ p.id }}</td>
                   {# ========== EXAMENS ==========            <td>{{ p.datePrescription ? p.datePrescription|date('Y-m-d H:i') : '-' }}</td>  #}   
                                <td>{{ p.commentaire ?? '-' }}</td>
                                <td class="text-end">
                                    {{ p.lignes is defined ? p.lignes|length : 0 }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-muted">Aucune prescription pour le moment.</div>
            {% endif %}
        </div>

        <div class="card mb-3">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h6 class="mb-0">Prescription</h6>
    <span class="badge bg-light text-dark border">
      {{ consultation.prescriptions|length }} document(s)
    </span>
  </div>
  <div class="card-body" id="prescriptionSummary">
    {% include 'prescription/_summary.html.twig' with { consultation: consultation } %}
  </div>
</div>

        {# ========== EXAMENS ========== #}
        <div class="tab-pane fade" id="pane-examens" role="tabpanel">
            {% if consultation.examensDemandes is defined and consultation.examensDemandes|length > 0 %}
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Libellé</th>
                            <th>Urgence</th>
                            <th>Statut</th>
                            <th>Note</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for e in consultation.examensDemandes %}
                            <tr>
                                <td>{{ e.id }}</td>
                                <td>{{ e.libelle ?? '-' }}</td>
                                <td>
                                    {% if e.urgence %}
                                        <span class="badge bg-danger">Urgent</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Non</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {{ e.statut.name ?? e.statut.value ?? '-' }}
                                </td>
                                <td>{{ e.note ?? '-' }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-muted">Aucun examen demandé pour le moment.</div>
            {% endif %}
        </div>

        {# ========== ACTES ========== #}
        <div class="tab-pane fade" id="pane-actes" role="tabpanel">
            {% if consultation.actesRealises is defined and consultation.actesRealises|length > 0 %}
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Libellé</th>
                            <th>Quantité</th>
                            <th>PU</th>
                            <th>Note</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for a in consultation.actesRealises %}
                            <tr>
                                <td>{{ a.id }}</td>
                                <td>{{ a.libelle ?? '-' }}</td>
                                <td>{{ a.quantite ?? 1 }}</td>
                                <td>{{ a.prixUnitaire ?? '-' }}</td>
                                <td>{{ a.note ?? '-' }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-muted">Aucun acte réalisé pour le moment.</div>
            {% endif %}
        </div>

    </div>
</div>

{# =========================
   MODAL EDIT CONSULTATION (AJAX)
========================= #}
<div class="modal fade" id="editConsultationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-pen me-2 text-primary"></i> Modifier la consultation
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <div id="editConsultationLoader" class="py-5 text-center">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
          <div class="mt-2 text-muted small">Chargement du formulaire…</div>
        </div>

        <div id="editConsultationModalBody" class="d-none"></div>
      </div>

      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">
          Fermer
        </button>
      </div>

    </div>
  </div>
</div>

{# =========================
   MODAL FACTURE (AJAX)
========================= #}
<div class="modal fade" id="factureModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-body p-0">
        <div class="p-4 text-center text-muted">Chargement...</div>
      </div>
    </div>
  </div>
</div>

{# =========================
   MODAL RESUME PRESCRIPTION (AJAX)
========================= #}

<div class="modal fade" id="prescriptionModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-body p-4 text-center text-muted">Chargement...</div>
    </div>
  </div>
</div>
{% endblock %}
{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      const editModalEl = document.getElementById('editConsultationModal');
      const loader = document.getElementById('editConsultationLoader');
      const body = document.getElementById('editConsultationModalBody');

      let currentUrl = null;

      function showError(message) {
        loader.classList.add('d-none');
        body.classList.remove('d-none');
        body.innerHTML = `
          <div class="alert alert-danger d-flex align-items-start gap-2 mb-0" role="alert">
            <i class="fa fa-exclamation-triangle mt-1"></i>
            <div>
              <div class="fw-semibold">Erreur</div>
              <div class="small">${message || 'Impossible de charger le formulaire.'}</div>
            </div>
          </div>
        `;
      }

      function setLoading() {
        loader.classList.remove('d-none');
        body.classList.add('d-none');
        body.innerHTML = '';
      }

      function focusFirstField() {
        const first = body.querySelector('input, select, textarea');
        if (first) first.focus();
      }

      async function loadEditForm(url) {
        currentUrl = url;
        setLoading();

        const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);

        const html = await res.text();
        body.innerHTML = html;

        loader.classList.add('d-none');
        body.classList.remove('d-none');

        focusFirstField();

        const form = body.querySelector('form');
        if (!form) return;

        form.addEventListener('submit', async (ev) => {
          ev.preventDefault();

          // Désactiver le bouton submit pendant l'envoi
          const submitBtn = form.querySelector('[type="submit"]');
          const oldSubmitHtml = submitBtn ? submitBtn.innerHTML : null;
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span> Enregistrement...`;
          }

          try {
            const formData = new FormData(form);
            const submitUrl = form.getAttribute('action') || currentUrl;
            const method = (form.getAttribute('method') || 'POST').toUpperCase();

            const submitRes = await fetch(submitUrl, {
              method,
              body: formData,
              headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            const contentType = submitRes.headers.get('content-type') || '';

            // JSON => succès attendu
            if (contentType.includes('application/json')) {
              const json = await submitRes.json();
              if (json.success) {
                bootstrap.Modal.getInstance(editModalEl)?.hide();

                // Option pro: refresh simple (tu peux remplacer par fetch + update row plus tard)
                window.location.reload();
                return;
              }
            }

            // Sinon HTML (form avec erreurs)
            const submitHtml = await submitRes.text();
            body.innerHTML = submitHtml;
            focusFirstField();
          } catch (err) {
            showError("Une erreur est survenue lors de l'enregistrement.");
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = oldSubmitHtml;
            }
          }
        }, { once: true });
      }

      document.addEventListener('click', (e) => {
        const btn = e.target.closest('.js-edit-consultation');
        if (!btn) return;

        const url = btn.getAttribute('data-url');
        if (!url) return;

        loadEditForm(url).catch((err) => {
          showError("Impossible de charger le formulaire. Vérifie la route et la réponse AJAX.");
        });
      });

      editModalEl?.addEventListener('hidden.bs.modal', () => {
        currentUrl = null;
        setLoading();
      });
    })();
  </script>
  <script>
/* =========================
   1) Ouvrir modal Prescription (GET)
========================= */
document.addEventListener('click', async (e) => {
  const openBtn = e.target.closest('.js-open-prescription');
  if (!openBtn) return;

  const url = openBtn.dataset.url;
  const modalEl = document.querySelector('#prescriptionModal');
  const content = modalEl.querySelector('.modal-content');

  content.innerHTML = `<div class="modal-body p-4 text-center text-muted">Chargement...</div>`;
  const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
  content.innerHTML = await res.text();
});

/* =========================
   2) Ajouter une ligne (prototype)
========================= */
document.addEventListener('click', (e) => {
  const addBtn = e.target.closest('.js-add-line');
  if (!addBtn) return;

  const container = document.querySelector('#prescriptionLines');
  if (!container) return;

  const prototype = container.dataset.prototype;
  let index = parseInt(container.dataset.index || '0', 10);

  const html = prototype.replace(/__name__/g, index);
  container.insertAdjacentHTML('beforeend', html);

  container.dataset.index = (index + 1).toString();
});

/* =========================
   3) Supprimer une ligne
========================= */
document.addEventListener('click', (e) => {
  const rmBtn = e.target.closest('.js-remove-line');
  if (!rmBtn) return;

  const row = rmBtn.closest('.js-line-item');
  if (!row) return;

  // Si _delete existe (éléments existants), on coche _delete
  const del = row.querySelector('input[type="checkbox"][name$="[_delete]"]');
  if (del) {
    del.checked = true;
    row.classList.add('d-none');
    return;
  }

  // Sinon (nouvelle ligne non persistée) => on supprime du DOM
  row.remove();
});

/* =========================
   4) Submit AJAX + refresh résumé
========================= */
document.addEventListener('submit', async (e) => {
  const form = e.target.closest('#prescriptionForm');
  if (!form) return;

  e.preventDefault();

  const modalEl = document.querySelector('#prescriptionModal');
  const content = modalEl.querySelector('.modal-content');
  const btn = content.querySelector('.js-submit-prescription');
  if (btn) btn.disabled = true;

  const res = await fetch(form.action, {
    method: 'POST',
    body: new FormData(form),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });

  if (res.ok) {
    const data = await res.json().catch(() => null);
    if (data?.success) {
      const summary = document.querySelector('#prescriptionSummary');
      if (summary && data.summaryHtml) summary.innerHTML = data.summaryHtml;

      const bsModal = bootstrap.Modal.getInstance(modalEl);
      bsModal?.hide();
      return;
    }
  }

  // erreurs => replace modal content
  const data = await res.json().catch(() => null);
  if (data?.html) {
    content.innerHTML = data.html;
  } else {
    alert("Erreur lors de l'enregistrement de la prescription.");
  }
});
</script>

  <script>
    document.addEventListener('click', async (e) => {
    // Ouvrir modal facture
    const openBtn = e.target.closest('.js-open-facture');
    if (openBtn) {
        const url = openBtn.dataset.url;
        const modalEl = document.querySelector('#factureModal');
        const modalBody = modalEl.querySelector('.modal-content');

        modalBody.innerHTML = `<div class="modal-body p-4 text-center text-muted">Chargement...</div>`;

        const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        modalBody.innerHTML = await res.text();
        return;
    }

    // Payer
    const payBtn = e.target.closest('.js-payer-facture');
    if (payBtn) {
        const url = payBtn.dataset.url;
        const modalEl = document.querySelector('#factureModal');
        const select = modalEl.querySelector('#modePaiementSelect');
        const mode = select ? select.value : '';

        if (!mode) {
        alert('Veuillez sélectionner un mode de paiement.');
        return;
        }

        payBtn.disabled = true;

        const formData = new FormData();
        formData.append('modePaiement', mode);

        const res = await fetch(url, {
        method: 'POST',
        body: formData,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });

        const data = await res.json().catch(() => null);

        if (!res.ok || !data || data.success !== true) {
        payBtn.disabled = false;
        alert(data?.message ?? "Erreur lors du paiement.");
        return;
        }

        // Recharger le contenu du modal (pour afficher statut PAYE)
        const openUrl = modalEl.querySelector('.js-payer-facture')?.dataset?.reloadUrl
        || document.querySelector('.js-open-facture')?.dataset?.url;

        if (openUrl) {
        const r2 = await fetch(openUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        modalEl.querySelector('.modal-content').innerHTML = await r2.text();
        } else {
        location.reload();
        }
    }
    });
</script>
{% endblock %}